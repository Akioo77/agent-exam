# .env.example — copy to .env and fill in real values
# DO NOT commit your real .env file (it's already in .gitignore)

# MiniMax / Anthropic-compatible API key
# Get one from https://api.minimaxi.com (or your provider)
ANTHROPIC_API_KEY=sk-your-key-here

# API base URL — defaults to MiniMax's Anthropic-compatible endpoint.
# For real Anthropic API, set to https://api.anthropic.com
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# Model to use (defaults to MiniMax-M3)
# Other options: MiniMax-M2.7, claude-3-5-sonnet-latest, etc.
AGENT_MODEL=MiniMax-M3